{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://docblueprint-engine/schema/v1",
  "title": "DocBlueprint Configuration",
  "description": "Configuration schema for docblueprint-engine",
  "type": "object",
  "required": ["project"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "description", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name"
        },
        "description": {
          "type": "string",
          "description": "Short project description"
        },
        "version": {
          "type": "string",
          "description": "Project version (semver)",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "businessModel": {
      "type": "array",
      "description": "Business model types this project targets",
      "items": {
        "type": "string",
        "enum": ["B2B", "B2C", "B2B2C", "SaaS", "PaaS"]
      },
      "minItems": 1
    },
    "domain": {
      "type": "string",
      "description": "Primary business domain (e.g. fintech, healthtech, edtech)"
    },
    "compliance": {
      "type": "array",
      "description": "Compliance frameworks the project must satisfy",
      "items": {
        "type": "string",
        "enum": ["HIPAA", "GDPR", "SOC2", "PCI-DSS", "none"]
      }
    },
    "personas": {
      "type": "array",
      "description": "User personas for this project",
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "description"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique persona identifier (e.g. P1)"
          },
          "name": {
            "type": "string",
            "description": "Persona name"
          },
          "role": {
            "type": "string",
            "description": "Persona role or job title"
          },
          "description": {
            "type": "string",
            "description": "Brief description of this persona"
          }
        }
      }
    },
    "flows": {
      "type": "array",
      "description": "User flows / journeys tracked in the flow registry",
      "items": {
        "type": "object",
        "required": ["id", "name", "persona", "priority", "description"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique flow identifier (e.g. FLOW-001)"
          },
          "name": {
            "type": "string",
            "description": "Flow name"
          },
          "persona": {
            "type": "string",
            "description": "Persona ID this flow belongs to"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Flow priority"
          },
          "description": {
            "type": "string",
            "description": "What this flow covers"
          }
        }
      }
    },
    "stack": {
      "type": "object",
      "description": "Technology stack choices",
      "properties": {
        "backend": {
          "type": "string",
          "description": "Backend language / framework (e.g. Node.js + Express)"
        },
        "frontend": {
          "type": "string",
          "description": "Frontend framework (e.g. React + Next.js)"
        },
        "mobile": {
          "type": "string",
          "description": "Mobile framework (e.g. React Native, Flutter)"
        },
        "database": {
          "type": "string",
          "description": "Primary database (e.g. PostgreSQL)"
        },
        "cloud": {
          "type": "string",
          "description": "Cloud provider (e.g. AWS, GCP, Azure)"
        },
        "infra": {
          "type": "string",
          "description": "Infrastructure-as-code tool (e.g. Terraform, Pulumi)"
        },
        "containerisation": {
          "type": "string",
          "description": "Container orchestration (e.g. Kubernetes, ECS, none)"
        }
      }
    },
    "releaseModel": {
      "type": "string",
      "enum": ["continuous", "sprint-based", "manual", "mixed"],
      "description": "How releases are managed"
    },
    "featureFlags": {
      "type": "boolean",
      "description": "Whether the project uses feature flags"
    },
    "versioning": {
      "type": "boolean",
      "description": "Whether the project uses explicit API / product versioning"
    }
  }
}
